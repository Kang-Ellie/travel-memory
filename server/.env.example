# Neon(PostgreSQL) 콘솔에서 복사한 연결 문자열
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# 앱 접속 비밀번호 (프론트에서 최초 1회 입력, 이후 30일간 자동 로그인)
APP_PASSCODE=원하는비밀번호

# 세션 쿠키 서명용 임의의 긴 문자열 (예: openssl rand -hex 32)
SESSION_SECRET=아무렇게나-길고-무작위한-문자열

# Cloudflare Pages에 배포된 프론트 주소 (CORS 허용 origin)
FRONTEND_ORIGIN=https://travel-on.pages.dev

# 업로드 파일(사진·바우처) 저장소 — Cloudflare R2 (대시보드 → R2 → 버킷 → API 토큰에서 발급)
R2_ACCOUNT_ID=클라우드플레어-계정-ID
R2_ACCESS_KEY_ID=R2-access-key-id
R2_SECRET_ACCESS_KEY=R2-secret-access-key
R2_BUCKET_NAME=travel-on-uploads

PORT=8787
NODE_ENV=production
