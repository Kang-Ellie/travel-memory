{
  "name": "travel-on-server",
  "private": true,
  "version": "0.1.0",
  "description": "트래블 온 — Express + PostgreSQL(Neon) API 서버 (Railway 배포)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "migrate:create": "node-pg-migrate create --envPath .env --",
    "migrate:up": "node-pg-migrate up --envPath .env",
    "migrate:down": "node-pg-migrate down --envPath .env"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exifr": "^7.1.3",
    "express": "^4.19.2",
    "multer": "^2.0.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.12.0",
    "sharp": "^0.35.3",
    "tsx": "^4.16.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "typescript": "^5.8.0"
  }
}
